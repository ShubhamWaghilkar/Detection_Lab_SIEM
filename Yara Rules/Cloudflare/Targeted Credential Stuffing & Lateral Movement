rule correlation_brute_force_to_lateral_movement {
  meta:
    description = "WAF detects credential stuffing followed by XDR lateral movement detection"
    severity = "High"
    author = "Shubham"

  events:
    // Event A: Cloudflare Brute Force / Account Takeover detection
    $waf.metadata.vendor_name = "Cloudflare"
    $waf.security_result.category = "CREDENTIAL_STUFFING"
    $waf.target.user.userid = $target_user

    // Event B: Trend Micro sees lateral movement or suspicious login
    $xdr.metadata.vendor_name = "Trend Micro"
    $xdr.metadata.event_type = "USER_LOGIN"
    $xdr.target.user.userid = $target_user
    // Look for unusual login types (e.g., RDP/SSH between internal hosts)
    $xdr.extensions.auth.mechanism = "REMOTE_DESKTOP"

  match:
    $target_user over 1h

  outcome:
    $attacker_ips = array_distinct($waf.principal.ip)
    $impacted_hosts = array_distinct($xdr.principal.hostname)

  condition:
    $waf and $xdr
}
